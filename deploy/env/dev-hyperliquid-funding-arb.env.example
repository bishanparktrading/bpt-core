# Hyperliquid testnet — funding arb plumbing test.
#
# Identical to dev-hyperliquid.env apart from:
#   - BPT_STRATEGY_CONFIG points at the funding_arb.qa-hyperliquid wrapper
#   - Bridge args label the dashboard with the perp leg (PURR). The bridge
#     is single-symbol by design; both legs' MD ticks still flow because
#     bridge.live.toml sets instrument_id=0, but each message is labeled
#     with BPT_BRIDGE_SYMBOL regardless of which leg emitted it. Proper
#     paired-leg dashboard view is future work.
#
# Copy into a local .env (the .env files are gitignored):
#   cp deploy/env/dev-hyperliquid-funding-arb.env.example \
#      deploy/env/dev-hyperliquid-funding-arb.env
# Activate:    ./deploy/switch-env.sh dev-hyperliquid-funding-arb
# Restart:     systemctl --user daemon-reload && systemctl --user restart bpt-stack.target
# Watch logs:  journalctl --user -fu bpt-strategy
BPT_REFDATA_CONFIG=config/bpt-refdata.qa-hyperliquid.toml
BPT_MD_GATEWAY_CONFIG=config/bpt-md-gateway.qa-hyperliquid.toml
BPT_ORDER_GATEWAY_CONFIG=config/bpt-order-gateway.qa-hyperliquid.toml
BPT_STRATEGY_CONFIG=config/funding_arb.qa-hyperliquid.toml
BPT_ANALYTICS_CONFIG=config/bpt-analytics.qa-hyperliquid.toml
BPT_PMS_CONFIG=config/bpt-pms.qa-hyperliquid.toml
BPT_BRIDGE_CONFIG=dashboard/bridge/config/bridge.live.toml
BPT_BRIDGE_PROFILE=deploy/config/profile/qa-hyperliquid.toml
BPT_BRIDGE_MODE=paper
BPT_BRIDGE_STRATEGY=FundingArbStrategy
BPT_BRIDGE_SYMBOL=PURR
BPT_BRIDGE_EXCHANGE=HYPERLIQUID
BPT_BRIDGE_INST_TYPE=PERP
BPT_ENV=dev
